{
  "expo": {
    "name": "ProjetoFETEPS",
    "slug": "intelliNest",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/rcsplash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fefefe"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.direzze.intelliNest",
